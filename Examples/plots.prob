X ~ Bin(5, 0.5)
Z ~ N(10, 2)

// Tablas de distribución
table(X)                     // Tabla completa (si el lenguaje lo permite)
table(X, 0, 5)               // Tabla de X desde 0 hasta 5

// Gráficos
plot(X)
plot(Z)

// Otras funciones de masa/densidad
print(maxP(X))               // Valor x que maximiza la probabilidad (Moda)
print(mode(X))               // Sinónimo o similar según tu AST


Y ~Poi (10)
plot(Y)